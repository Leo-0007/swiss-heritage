# ============================================
# Swiss Heritage - Variables d'environnement
# ============================================
# IMPORTANT: Ce fichier est un TEMPLATE.
# Copier vers .env et remplir avec les vraies valeurs.
# NE JAMAIS commiter le fichier .env reel !
# ============================================

# --- N8N ---
N8N_BASE_URL=https://n8n.swiss-leads.ch
N8N_WEBHOOK_PATH_TEST=/webhook-test/lpp-form
N8N_WEBHOOK_PATH_PROD=/webhook/lpp-form

# --- Google Sheets (CRM) ---
GOOGLE_SHEETS_ID=your_spreadsheet_id_here
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# --- SMTP (Emails) ---
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_sendgrid_api_key_here
SMTP_FROM_EMAIL=info@swiss-heritage.ch
SMTP_FROM_NAME=Swiss Heritage

# --- Admin ---
ADMIN_EMAIL=lionel.ndombele@gmail.com

# --- WhatsApp (Phase 2) ---
# TWILIO_ACCOUNT_SID=your_twilio_sid
# TWILIO_AUTH_TOKEN=your_twilio_token
# TWILIO_WHATSAPP_NUMBER=whatsapp:+41xxxxxxxxx

# --- Skribble e-signature (Phase 3) ---
# SKRIBBLE_API_KEY=your_skribble_key
# SKRIBBLE_API_SECRET=your_skribble_secret

# --- Kala API (Quand disponible) ---
# KALA_API_URL=https://api.kala.ch
# KALA_API_KEY=your_kala_api_key
# KALA_CALLBACK_URL=https://n8n.swiss-leads.ch/webhook/kala-callback

# --- Monitoring (Phase 5) ---
# MONITORING_WEBHOOK=https://n8n.swiss-leads.ch/webhook/health-alert
