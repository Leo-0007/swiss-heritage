{
  "name": "Swiss Heritage - Workflow Principal LPP",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "lpp-form",
        "responseMode": "responseNode",
        "options": {
          "allowedOrigins": "https://swiss-heritage.ch,https://*.netlify.app"
        }
      },
      "id": "webhook-formulaire",
      "name": "📥 Webhook Formulaire",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [250, 400],
      "webhookId": "lpp-form"
    },
    {
      "parameters": {
        "values": {
          "string": [
            {
              "name": "lead_id",
              "value": "=LPP_{{$json.body.email.replace('@', '_at_')}}_{{$now.toFormat('yyyyMMddHHmmss')}}"
            },
            {
              "name": "name",
              "value": "={{$json.body.name}}"
            },
            {
              "name": "email",
              "value": "={{$json.body.email}}"
            },
            {
              "name": "phone",
              "value": "={{$json.body.phone}}"
            },
            {
              "name": "timestamp",
              "value": "={{$json.body.timestamp || $now.toISO()}}"
            },
            {
              "name": "source",
              "value": "={{$json.body.source || 'website'}}"
            },
            {
              "name": "status",
              "value": "nouveau"
            },
            {
              "name": "date_fr",
              "value": "={{$now.toFormat('dd/MM/yyyy HH:mm')}}"
            }
          ]
        },
        "options": {}
      },
      "id": "extraire-donnees",
      "name": "🔄 Extraire & Formatter",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.3,
      "position": [450, 400]
    },
    {
      "parameters": {
        "authentication": "serviceAccount",
        "resource": "sheet",
        "operation": "append",
        "documentId": {
          "__rl": true,
          "value": "VOTRE_GOOGLE_SHEET_ID",
          "mode": "id",
          "cachedResultName": "Swiss Heritage - CRM Leads"
        },
        "sheetName": {
          "__rl": true,
          "value": "gid=0",
          "mode": "id",
          "cachedResultName": "Leads"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "lead_id": "={{$json.lead_id}}",
            "date": "={{$json.date_fr}}",
            "nom": "={{$json.name}}",
            "email": "={{$json.email}}",
            "telephone": "={{$json.phone}}",
            "source": "={{$json.source}}",
            "statut": "={{$json.status}}",
            "timestamp": "={{$json.timestamp}}"
          }
        },
        "options": {}
