      "id": "google-sheets-crm",
      "name": "📊 Enregistrer CRM (Google Sheets)",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.4,
      "position": [650, 400],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "VOTRE_CREDENTIAL_ID",
          "name": "Google Sheets OAuth2"
        }
      }
