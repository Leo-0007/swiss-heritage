    {
      "parameters": {
        "fromEmail": "noreply@swiss-heritage.ch",
        "toEmail": "={{$json.email}}",
        "subject": "🏦 Bienvenue chez Swiss Heritage",
        "emailType": "html",
        "message": "=<!DOCTYPE html>\n<html>\n<head>\n  <style>\n    body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f5f5f5; margin: 0; padding: 0; }\n    .container { max-width: 600px; margin: 40px auto; background: white; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,0.1); }\n    .header { background: linear-gradient(135deg, #0c192f 0%, #1a2d4a 100%); color: white; padding: 40px 30px; text-align: center; }\n    .logo { font-size: 32px; margin-bottom: 10px; }\n    .content { padding: 40px 30px; }\n    .highlight { color: #c9a962; font-weight: bold; }\n    .steps { background: #fafafa; padding: 20px; border-radius: 8px; margin: 20px 0; }\n    .step { margin: 15px 0; padding-left: 25px; position: relative; }\n    .step:before { content: '✓'; position: absolute; left: 0; color: #4ade80; font-weight: bold; }\n    .cta { text-align: center; margin: 30px 0; }\n    .button { display: inline-block; background: linear-gradient(135deg, #c9a962 0%, #e8d5a3 100%); color: #0c192f; padding: 15px 35px; border-radius: 8px; text-decoration: none; font-weight: bold; }\n    .footer { background: #f5f5f5; padding: 20px; text-align: center; font-size: 12px; color: #888; }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <div class=\"header\">\n      <div class=\"logo\">◆ Swiss Heritage</div>\n      <h1 style=\"margin: 0; font-size: 24px;\">Bienvenue !</h1>\n    </div>\n    <div class=\"content\">\n      <p>Bonjour <strong>{{$json.name}}</strong>,</p>\n      <p>Merci pour votre confiance ! Nous avons bien reçu votre demande de recherche d'avoirs LPP.</p>\n      \n      <div class=\"steps\">\n        <h3 style=\"margin-top: 0; color: #0c192f;\">Prochaines étapes :</h3>\n        <div class=\"step\">Notre équipe analyse votre dossier</div>\n        <div class=\"step\">Nous lançons la recherche auprès de <span class=\"highlight\">1500+ instituts</span></div>\n        <div class=\"step\">Vous recevrez un rapport détaillé sous <span class=\"highlight\">90 jours</span></div>\n      </div>\n\n      <p><strong>Rappel :</strong> Ce service est <span class=\"highlight\">100% gratuit</span> et sans engagement.</p>\n\n      <div class=\"cta\">\n        <p style=\"margin-bottom: 15px;\">Des questions ? Notre équipe est à votre disposition :</p>\n        <a href=\"mailto:contact@swiss-heritage.ch\" class=\"button\">Nous contacter</a>\n      </div>\n\n      <p style=\"margin-top: 30px; font-size: 14px; color: #666;\">\n        <strong>Vos informations :</strong><br>\n        📧 Email : {{$json.email}}<br>\n        📱 Téléphone : {{$json.phone}}<br>\n        🆔 Référence : {{$json.lead_id}}\n      </p>\n    </div>\n    <div class=\"footer\">\n      <p>Swiss Heritage SA - Experts en prévoyance LPP<br>\n      Genève, Suisse 🇨🇭</p>\n      <p style=\"margin-top: 10px;\">\n        🔒 Vos données sont sécurisées et ne seront jamais partagées\n      </p>\n    </div>\n  </div>\n</body>\n</html>",
        "options": {
          "appendAttribution": false
        }
      },
      "id": "email-client",
      "name": "📧 Email Client (Confirmation)",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [850, 300],
      "credentials": {
        "smtp": {
          "id": "VOTRE_SMTP_ID",
          "name": "SMTP Account"
        }
      }
    },
    {
      "parameters": {
        "fromEmail": "noreply@swiss-heritage.ch",
        "toEmail": "admin@swiss-heritage.ch",
        "subject": "🚨 Nouveau Lead LPP - {{$json.name}}",
        "emailType": "html",
        "message": "=<!DOCTYPE html>\n<html>\n<head>\n  <style>\n    body { font-family: Arial, sans-serif; background: #f5f5f5; margin: 0; padding: 20px; }\n    .container { max-width: 600px; margin: 0 auto; background: white; border-radius: 8px; padding: 30px; }\n    .header { background: #0c192f; color: white; padding: 20px; border-radius: 8px 8px 0 0; margin: -30px -30px 20px; }\n    .info-box { background: #fafafa; padding: 15px; border-left: 4px solid #c9a962; margin: 15px 0; }\n    .label { color: #666; font-size: 12px; text-transform: uppercase; margin-top: 10px; }\n    .value { color: #0c192f; font-size: 16px; font-weight: bold; margin: 5px 0 15px; }\n    .urgent { background: #fef3c7; border-left-color: #f59e0b; }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <div class=\"header\">\n      <h2 style=\"margin: 0;\">🔔 Nouveau Lead LPP</h2>\n    </div>\n    \n    <div class=\"info-box urgent\">\n      <p style=\"margin: 0; font-weight: bold;\">⚡ Action requise : Contacter sous 24h</p>\n    </div>\n\n    <div class=\"info-box\">\n      <div class=\"label\">Nom complet</div>\n      <div class=\"value\">{{$json.name}}</div>\n      \n      <div class=\"label\">Email</div>\n      <div class=\"value\">{{$json.email}}</div>\n      \n      <div class=\"label\">Téléphone</div>\n      <div class=\"value\">{{$json.phone}}</div>\n      \n      <div class=\"label\">Date & Heure</div>\n      <div class=\"value\">{{$json.date_fr}}</div>\n      \n      <div class=\"label\">Source</div>\n      <div class=\"value\">{{$json.source}}</div>\n      \n      <div class=\"label\">ID Lead</div>\n      <div class=\"value\" style=\"font-size: 12px; color: #666;\">{{$json.lead_id}}</div>\n    </div>\n\n    <p style=\"text-align: center; margin-top: 30px;\">\n      <a href=\"https://docs.google.com/spreadsheets/d/VOTRE_SHEET_ID\" \n         style=\"display: inline-block; background: #0c192f; color: white; padding: 12px 30px; border-radius: 6px; text-decoration: none; font-weight: bold;\">\n        📊 Ouvrir le CRM\n      </a>\n    </p>\n  </div>\n</body>\n</html>",
        "options": {
          "appendAttribution": false
        }
      },
